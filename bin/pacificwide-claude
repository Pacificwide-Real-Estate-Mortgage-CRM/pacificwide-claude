#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# pacificwide-claude — Distribute team .claude/ config to any repo
# ─────────────────────────────────────────────────────────────────────────────

VERSION="1.1.0"
CLI_DIR="${HOME}/.pacificwide-claude"
CONFIG_SRC="${CLI_DIR}/config"
CLAUDE_DIR=".claude"
META_FILE="${CLAUDE_DIR}/.pacificwide-meta.json"

# Stack config
STACKS_DIR="${CONFIG_SRC}/stacks"
AVAILABLE_STACKS=("nestjs" "nextjs" "react-native")

# Protected files inside .claude/ — never overwritten by update/init
PROTECTED_FILES=(".env" "settings.local.json" ".pacificwide-meta.json")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ─── Helpers ──────────────────────────────────────────────────────────────────

info()    { echo -e "${BLUE}ℹ${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}⚠${NC} $*"; }
error()   { echo -e "${RED}✗${NC} $*" >&2; }

is_protected() {
  local file="$1"
  for p in "${PROTECTED_FILES[@]}"; do
    if [[ "$file" == "$p" || "$file" == *"/$p" ]]; then
      return 0
    fi
  done
  return 1
}

detect_stack() {
  local dir="${1:-.}"
  local pkg="${dir}/package.json"

  if [[ ! -f "$pkg" ]]; then
    echo ""
    return
  fi

  # Check dependencies and devDependencies for framework markers
  if grep -q '"@nestjs/core"' "$pkg" 2>/dev/null; then
    echo "nestjs"
  elif grep -q '"react-native"' "$pkg" 2>/dev/null; then
    echo "react-native"
  elif grep -q '"next"' "$pkg" 2>/dev/null; then
    echo "nextjs"
  else
    echo ""
  fi
}

sync_stack() {
  local target_dir="$1"
  local stack="$2"
  local count=0

  if [[ -z "$stack" ]]; then
    return
  fi

  local stack_dir="${STACKS_DIR}/${stack}"
  if [[ ! -d "$stack_dir" ]]; then
    warn "Stack '${stack}' not found in config/stacks/"
    return
  fi

  # Copy stack-rules.md → .claude/rules/stack-rules.md
  if [[ -f "${stack_dir}/stack-rules.md" ]]; then
    mkdir -p "${target_dir}/${CLAUDE_DIR}/rules"
    cp "${stack_dir}/stack-rules.md" "${target_dir}/${CLAUDE_DIR}/rules/stack-rules.md"
    count=$((count + 1))
  fi

  # Copy stack-specific skills → .claude/skills/
  if [[ -d "${stack_dir}/skills" ]]; then
    while IFS= read -r -d '' src_file; do
      local rel_path="${src_file#${stack_dir}/skills/}"
      local dest_file="${target_dir}/${CLAUDE_DIR}/skills/${rel_path}"
      mkdir -p "$(dirname "$dest_file")"
      cp "$src_file" "$dest_file"
      count=$((count + 1))
    done < <(find "${stack_dir}/skills" -type f -print0)
  fi

  echo "$count"
}

write_meta() {
  local dir="$1"
  local stack="${2:-}"
  cat > "${dir}/${META_FILE}" <<EOF
{
  "version": "${VERSION}",
  "stack": "${stack}",
  "lastSync": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "source": "pacificwide-claude"
}
EOF
}

check_cli_installed() {
  if [[ ! -d "$CLI_DIR" ]]; then
    error "pacificwide-claude not installed at ${CLI_DIR}"
    echo "  Run: curl -fsSL https://raw.githubusercontent.com/Pacificwide-Real-Estate-Mortgage-CRM/pacificwide-claude/main/install.sh | bash"
    exit 1
  fi
}

# MCP servers to register — name:url pairs
MCP_SERVERS=(
  "figma:https://mcp.figma.com/mcp"
  "notion:https://mcp.notion.com/mcp"
)

setup_mcp_servers() {
  if ! command -v claude &>/dev/null; then
    warn "Claude Code CLI not found. Skipping MCP setup."
    echo -e "  Install Claude Code, then run: ${BOLD}pacificwide-claude mcp${NC}"
    return
  fi

  echo ""
  info "Setting up MCP servers..."

  local added=0
  local skipped=0

  for entry in "${MCP_SERVERS[@]}"; do
    local name="${entry%%:*}"
    local url="${entry#*:}"

    # Check if already registered (claude mcp list output contains the name)
    if claude mcp list 2>/dev/null | grep -q "$name"; then
      skipped=$((skipped + 1))
    else
      if claude mcp add --transport http "$name" "$url" 2>/dev/null; then
        success "Added MCP: ${name} (${url})"
        added=$((added + 1))
      else
        warn "Failed to add MCP: ${name}. Add manually: claude mcp add --transport http ${name} ${url}"
      fi
    fi
  done

  if [[ $added -gt 0 || $skipped -gt 0 ]]; then
    echo -e "  ${CYAN}${added}${NC} MCP servers added, ${CYAN}${skipped}${NC} already configured"
  fi

  if [[ $added -gt 0 ]]; then
    echo ""
    info "MCP servers added. To authenticate:"
    echo -e "  1. Open Claude Code in this project"
    echo -e "  2. Type ${BOLD}/mcp${NC} → select server → ${BOLD}Authenticate${NC} → Allow access"
  fi
}

sync_config() {
  local target_dir="$1"
  local count=0
  local skipped=0

  # Walk config/ and copy to target, preserving directory structure
  # Skip stacks/ directory — handled separately by sync_stack()
  while IFS= read -r -d '' src_file; do
    # Get relative path from config/
    local rel_path="${src_file#${CONFIG_SRC}/}"

    # Skip stack-specific files (handled by sync_stack)
    if [[ "$rel_path" == stacks/* ]]; then
      continue
    fi
    local dest_file="${target_dir}/${CLAUDE_DIR}/${rel_path}"
    local dest_dir
    dest_dir="$(dirname "$dest_file")"

    # Skip protected files
    if is_protected "$rel_path"; then
      skipped=$((skipped + 1))
      continue
    fi

    # Check if destination exists and is protected
    local basename
    basename="$(basename "$rel_path")"
    if is_protected "$basename" && [[ -f "$dest_file" ]]; then
      skipped=$((skipped + 1))
      continue
    fi

    mkdir -p "$dest_dir"
    cp "$src_file" "$dest_file"
    count=$((count + 1))
  done < <(find "$CONFIG_SRC" -type f -print0)

  echo "${count}:${skipped}"
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_init() {
  check_cli_installed

  # Parse --stack flag
  local stack_override=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stack=*) stack_override="${1#--stack=}"; shift ;;
      --stack)   stack_override="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done

  if [[ -d "$CLAUDE_DIR" ]]; then
    warn ".claude/ already exists in this directory."
    read -r -p "  Overwrite team config files? (protected files preserved) [y/N] " answer
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
      info "Aborted."
      exit 0
    fi
  fi

  # Detect or use overridden stack
  local stack="${stack_override}"
  if [[ -z "$stack" ]]; then
    stack="$(detect_stack ".")"
  fi

  if [[ -n "$stack" ]]; then
    info "Detected stack: ${BOLD}${stack}${NC}"
  else
    warn "No stack detected from package.json. Only shared config will be synced."
    info "Use ${BOLD}--stack=<name>${NC} to specify (${AVAILABLE_STACKS[*]})"
  fi

  info "Initializing .claude/ with team config..."
  mkdir -p "$CLAUDE_DIR"

  # Sync shared config files
  local result
  result="$(sync_config ".")"
  local count="${result%%:*}"
  local skipped="${result##*:}"

  # Sync stack-specific files
  local stack_count=0
  if [[ -n "$stack" ]]; then
    stack_count="$(sync_stack "." "$stack")"
    stack_count="${stack_count:-0}"
  fi

  # Copy .env.example if exists and .env doesn't
  if [[ -f "${CLI_DIR}/.env.example" && ! -f "${CLAUDE_DIR}/.env" ]]; then
    cp "${CLI_DIR}/.env.example" "${CLAUDE_DIR}/.env"
    success "Created .claude/.env from template"
  fi

  # Copy .mcp.json.example to project root (Claude Code reads .mcp.json at project root, not inside .claude/)
  if [[ -f "${CLI_DIR}/.mcp.json.example" && ! -f ".mcp.json" ]]; then
    cp "${CLI_DIR}/.mcp.json.example" ".mcp.json"
    success "Created .mcp.json (project root)"
  fi

  # Migrate: if old .claude/.mcp.json exists but root doesn't, move it
  if [[ -f "${CLAUDE_DIR}/.mcp.json" && ! -f ".mcp.json" ]]; then
    mv "${CLAUDE_DIR}/.mcp.json" ".mcp.json"
    success "Migrated .claude/.mcp.json → .mcp.json (project root)"
  elif [[ -f "${CLAUDE_DIR}/.mcp.json" && -f ".mcp.json" ]]; then
    rm -f "${CLAUDE_DIR}/.mcp.json"
  fi

  # Write meta
  write_meta "." "$stack"

  echo ""
  success "Initialized .claude/ with team config"
  echo -e "  ${CYAN}${count}${NC} shared files synced, ${CYAN}${stack_count}${NC} stack files (${stack:-none}), ${CYAN}${skipped}${NC} protected skipped"
  echo ""
  echo -e "  ${BOLD}Structure:${NC}"
  find "$CLAUDE_DIR" -type f | sort | sed 's/^/    /'
  echo ""

  # Setup MCP servers
  setup_mcp_servers

  info "Run ${BOLD}pacificwide-claude doctor${NC} to verify setup."
}

cmd_update() {
  check_cli_installed

  if [[ ! -f "$META_FILE" ]]; then
    error "Not a pacificwide-claude project. Run ${BOLD}pacificwide-claude init${NC} first."
    exit 1
  fi

  # Parse --stack flag
  local stack_override=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stack=*) stack_override="${1#--stack=}"; shift ;;
      --stack)   stack_override="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done

  info "Pulling latest config..."
  if git -C "$CLI_DIR" pull --ff-only 2>/dev/null; then
    success "Config repo updated"
  else
    warn "Could not pull (offline or no changes). Using local config."
  fi

  # Determine stack: flag > meta > auto-detect
  local stack="${stack_override}"
  if [[ -z "$stack" ]]; then
    stack="$(grep '"stack"' "$META_FILE" 2>/dev/null | sed 's/.*: *"\(.*\)".*/\1/' || echo "")"
  fi
  if [[ -z "$stack" ]]; then
    stack="$(detect_stack ".")"
  fi

  if [[ -n "$stack" ]]; then
    info "Stack: ${BOLD}${stack}${NC}"
  fi

  info "Syncing config/ → .claude/ ..."
  local result
  result="$(sync_config ".")"
  local count="${result%%:*}"
  local skipped="${result##*:}"

  # Sync stack-specific files
  local stack_count=0
  if [[ -n "$stack" ]]; then
    stack_count="$(sync_stack "." "$stack")"
    stack_count="${stack_count:-0}"
  fi

  # Update meta
  write_meta "." "$stack"

  echo ""
  success "Update complete"
  echo -e "  ${CYAN}${count}${NC} shared files, ${CYAN}${stack_count}${NC} stack files (${stack:-none}), ${CYAN}${skipped}${NC} protected preserved"
}

cmd_doctor() {
  check_cli_installed

  local pass=0
  local fail=0

  echo -e "${BOLD}pacificwide-claude doctor${NC}"
  echo ""

  # 1. CLI version vs remote
  echo -n "  CLI installed at ${CLI_DIR}... "
  if [[ -d "$CLI_DIR" ]]; then
    echo -e "${GREEN}PASS${NC} (v${VERSION})"
    pass=$((pass + 1))
  else
    echo -e "${RED}FAIL${NC}"
    fail=$((fail + 1))
  fi

  # 2. .claude/ exists + has meta.json
  echo -n "  .claude/ exists with meta... "
  if [[ -f "$META_FILE" ]]; then
    local last_sync
    last_sync="$(grep '"lastSync"' "$META_FILE" 2>/dev/null | sed 's/.*: *"\(.*\)".*/\1/' || echo "unknown")"
    echo -e "${GREEN}PASS${NC} (last sync: ${last_sync})"
    pass=$((pass + 1))
  elif [[ -d "$CLAUDE_DIR" ]]; then
    echo -e "${YELLOW}WARN${NC} (.claude/ exists but no meta — run ${BOLD}pacificwide-claude init${NC})"
    fail=$((fail + 1))
  else
    echo -e "${RED}FAIL${NC} (no .claude/ found — run ${BOLD}pacificwide-claude init${NC})"
    fail=$((fail + 1))
  fi

  # 3. Validate structure
  local dirs=("agents" "rules" "skills")
  for dir in "${dirs[@]}"; do
    echo -n "  .claude/${dir}/ exists... "
    if [[ -d "${CLAUDE_DIR}/${dir}" ]]; then
      local file_count
      file_count="$(find "${CLAUDE_DIR}/${dir}" -type f | wc -l | tr -d ' ')"
      echo -e "${GREEN}PASS${NC} (${file_count} files)"
      pass=$((pass + 1))
    else
      echo -e "${RED}FAIL${NC}"
      fail=$((fail + 1))
    fi
  done

  # 4. Check Node.js >= 18
  echo -n "  Node.js >= 18... "
  if command -v node &>/dev/null; then
    local node_ver
    node_ver="$(node -v | sed 's/v//' | cut -d. -f1)"
    if [[ "$node_ver" -ge 18 ]]; then
      echo -e "${GREEN}PASS${NC} ($(node -v))"
      pass=$((pass + 1))
    else
      echo -e "${RED}FAIL${NC} ($(node -v) — need >= 18)"
      fail=$((fail + 1))
    fi
  else
    echo -e "${RED}FAIL${NC} (not installed)"
    fail=$((fail + 1))
  fi

  # 5. Check git
  echo -n "  git installed... "
  if command -v git &>/dev/null; then
    echo -e "${GREEN}PASS${NC} ($(git --version | head -1))"
    pass=$((pass + 1))
  else
    echo -e "${RED}FAIL${NC}"
    fail=$((fail + 1))
  fi

  # 6. Check Claude Code CLI
  echo -n "  Claude Code CLI... "
  if command -v claude &>/dev/null; then
    echo -e "${GREEN}PASS${NC}"
    pass=$((pass + 1))
  else
    echo -e "${YELLOW}WARN${NC} (not found — install from https://claude.ai/code)"
    fail=$((fail + 1))
  fi

  # 7. Stack detection
  local stack
  stack="$(grep '"stack"' "$META_FILE" 2>/dev/null | sed 's/.*: *"\(.*\)".*/\1/' || echo "")"
  local detected
  detected="$(detect_stack ".")"
  echo -n "  Stack... "
  if [[ -n "$stack" ]]; then
    echo -e "${GREEN}${stack}${NC} (from meta)"
    pass=$((pass + 1))
  elif [[ -n "$detected" ]]; then
    echo -e "${YELLOW}${detected}${NC} (auto-detected, not in meta — run ${BOLD}pacificwide-claude update${NC})"
    fail=$((fail + 1))
  else
    echo -e "${YELLOW}WARN${NC} (no stack detected)"
    fail=$((fail + 1))
  fi

  # 8. stack-rules.md exists
  echo -n "  .claude/rules/stack-rules.md... "
  if [[ -f "${CLAUDE_DIR}/rules/stack-rules.md" ]]; then
    echo -e "${GREEN}PASS${NC}"
    pass=$((pass + 1))
  elif [[ -n "$stack" || -n "$detected" ]]; then
    echo -e "${RED}FAIL${NC} (missing — run ${BOLD}pacificwide-claude update${NC})"
    fail=$((fail + 1))
  else
    echo -e "${YELLOW}SKIP${NC} (no stack)"
    pass=$((pass + 1))
  fi

  # 9. .mcp.json exists at project root with required MCPs
  echo -n "  .mcp.json (project root)... "
  if [[ -f ".mcp.json" ]]; then
    local has_notion=false
    local has_figma=false
    grep -q '"notion"' ".mcp.json" 2>/dev/null && has_notion=true
    grep -q '"figma"' ".mcp.json" 2>/dev/null && has_figma=true

    if [[ "$has_notion" == true && "$has_figma" == true ]]; then
      echo -e "${GREEN}PASS${NC} (notion + figma)"
      pass=$((pass + 1))
    elif [[ "$has_notion" == true ]]; then
      echo -e "${YELLOW}WARN${NC} (notion ✓, figma missing — add figma MCP for design workflow)"
      fail=$((fail + 1))
    elif [[ "$has_figma" == true ]]; then
      echo -e "${YELLOW}WARN${NC} (figma ✓, notion missing — add notion MCP for ticket workflow)"
      fail=$((fail + 1))
    else
      echo -e "${YELLOW}WARN${NC} (no figma or notion MCP configured)"
      fail=$((fail + 1))
    fi
  else
    echo -e "${YELLOW}WARN${NC} (missing — run ${BOLD}pacificwide-claude init${NC} to create from template)"
    fail=$((fail + 1))
  fi

  echo ""
  if [[ $fail -eq 0 ]]; then
    success "All checks passed (${pass}/${pass})"
  else
    warn "${pass} passed, ${fail} failed"
  fi
}

cmd_list() {
  check_cli_installed

  local category="${1:-all}"

  echo -e "${BOLD}pacificwide-claude config${NC}"
  echo ""

  # Show stack info
  local stack=""
  if [[ -f "$META_FILE" ]]; then
    stack="$(grep '"stack"' "$META_FILE" 2>/dev/null | sed 's/.*: *"\(.*\)".*/\1/' || echo "")"
  fi
  if [[ -n "$stack" ]]; then
    echo -e "  ${BOLD}Stack:${NC} ${GREEN}${stack}${NC}"
  else
    local detected
    detected="$(detect_stack ".")"
    if [[ -n "$detected" ]]; then
      echo -e "  ${BOLD}Stack:${NC} ${YELLOW}${detected}${NC} (auto-detected, run update to sync)"
    else
      echo -e "  ${BOLD}Stack:${NC} (none)"
    fi
  fi
  echo -e "  ${BOLD}Available stacks:${NC} ${AVAILABLE_STACKS[*]}"
  echo ""

  list_category() {
    local name="$1"
    local config_dir="$2"
    local claude_dir="$3"

    echo -e "  ${BOLD}${name}:${NC}"
    if [[ ! -d "$config_dir" ]]; then
      echo "    (none)"
      return
    fi

    while IFS= read -r file; do
      local rel="${file#${config_dir}/}"
      local basename
      basename="$(basename "$rel" .md)"
      basename="$(basename "$basename" .MD)"
      # Check if it's a SKILL.md (skill dir structure)
      if [[ "$basename" == "SKILL" ]]; then
        basename="$(basename "$(dirname "$rel")")"
      fi

      local status=""
      local dest="${claude_dir}/${rel}"
      if [[ -f "$dest" ]]; then
        status="${GREEN}active${NC}"
      else
        status="${YELLOW}available${NC}"
      fi

      echo -e "    ${basename}  [${status}]"
    done < <(find "$config_dir" -type f \( -name "*.md" -o -name "*.MD" \) | sort)
    echo ""
  }

  if [[ "$category" == "all" || "$category" == "agents" ]]; then
    list_category "Agents" "${CONFIG_SRC}/agents" "${CLAUDE_DIR}/agents"
  fi
  if [[ "$category" == "all" || "$category" == "rules" ]]; then
    list_category "Rules" "${CONFIG_SRC}/rules" "${CLAUDE_DIR}/rules"
  fi
  if [[ "$category" == "all" || "$category" == "skills" ]]; then
    list_category "Skills (shared)" "${CONFIG_SRC}/skills" "${CLAUDE_DIR}/skills"
    if [[ -n "$stack" ]]; then
      list_category "Skills (${stack})" "${STACKS_DIR}/${stack}/skills" "${CLAUDE_DIR}/skills"
    fi
  fi
  if [[ "$category" == "all" || "$category" == "stacks" ]]; then
    echo -e "  ${BOLD}Stacks:${NC}"
    for s in "${AVAILABLE_STACKS[@]}"; do
      local marker=""
      if [[ "$s" == "$stack" ]]; then
        marker=" ${GREEN}← active${NC}"
      fi
      local skill_count=0
      if [[ -d "${STACKS_DIR}/${s}/skills" ]]; then
        skill_count="$(find "${STACKS_DIR}/${s}/skills" -name "SKILL.md" | wc -l | tr -d ' ')"
      fi
      echo -e "    ${s} (${skill_count} skills)${marker}"
    done
    echo ""
  fi
}

cmd_reset() {
  check_cli_installed

  warn "This will remove .claude/ and re-initialize from team config."
  read -r -p "  Continue? [y/N] " answer
  if [[ ! "$answer" =~ ^[Yy]$ ]]; then
    info "Aborted."
    exit 0
  fi

  # Backup protected files inside .claude/
  local backup_dir
  backup_dir="$(mktemp -d)"
  local backed_up=()

  for file in "${PROTECTED_FILES[@]}"; do
    if [[ -f "${CLAUDE_DIR}/${file}" ]]; then
      mkdir -p "${backup_dir}/$(dirname "$file")"
      cp "${CLAUDE_DIR}/${file}" "${backup_dir}/${file}"
      backed_up+=("$file")
    fi
  done

  # Backup .mcp.json at project root (not inside .claude/)
  if [[ -f ".mcp.json" ]]; then
    cp ".mcp.json" "${backup_dir}/.mcp.json"
    backed_up+=(".mcp.json (root)")
  fi

  if [[ ${#backed_up[@]} -gt 0 ]]; then
    info "Backed up protected files: ${backed_up[*]}"
  fi

  # Remove .claude/
  rm -rf "$CLAUDE_DIR"
  success "Removed .claude/"

  # Re-init
  cmd_init

  # Restore backups (inside .claude/)
  for file in "${PROTECTED_FILES[@]}"; do
    if [[ -f "${backup_dir}/${file}" ]]; then
      cp "${backup_dir}/${file}" "${CLAUDE_DIR}/${file}"
      success "Restored ${file}"
    fi
  done

  # Restore .mcp.json at project root
  if [[ -f "${backup_dir}/.mcp.json" ]]; then
    cp "${backup_dir}/.mcp.json" ".mcp.json"
    success "Restored .mcp.json (root)"
  fi

  rm -rf "$backup_dir"
  echo ""
  success "Reset complete. Protected files preserved."
}

cmd_mcp() {
  check_cli_installed
  setup_mcp_servers
}

cmd_self_update() {
  check_cli_installed

  info "Updating pacificwide-claude..."
  if git -C "$CLI_DIR" pull --ff-only; then
    local new_version
    new_version="$(grep '^VERSION=' "${CLI_DIR}/bin/pacificwide-claude" | head -1 | cut -d'"' -f2)"
    echo ""
    success "Updated to v${new_version:-${VERSION}}"
  else
    error "Failed to update. Check your network or git config."
    exit 1
  fi
}

cmd_version() {
  echo "pacificwide-claude v${VERSION}"
}

cmd_help() {
  cat <<EOF
${BOLD}pacificwide-claude${NC} v${VERSION} — Team .claude/ config manager

${BOLD}USAGE${NC}
  pacificwide-claude <command> [options]

${BOLD}COMMANDS${NC}
  init [--stack=<name>]   Initialize .claude/ with team config (auto-detects stack)
  update [--stack=<name>] Pull latest config and sync to .claude/
  doctor                  Check setup, environment, and stack
  list [category]         List config (agents|rules|skills|stacks|all)
  mcp                     Register MCP servers (Figma, Notion) with Claude Code
  reset                   Remove .claude/ and re-initialize (preserves .env)
  self-update             Update the CLI itself
  version                 Show version
  help                    Show this help

${BOLD}STACK AUTO-DETECTION${NC}
  Reads package.json to detect framework:
    @nestjs/core   → nestjs     (NestJS backend)
    next           → nextjs     (Next.js frontend)
    react-native   → react-native (React Native app)

  Use --stack=<name> to override auto-detection.

${BOLD}EXAMPLES${NC}
  # Auto-detect stack from package.json
  pacificwide-claude init

  # Force a specific stack
  pacificwide-claude init --stack=nextjs

  # Get latest team config
  pacificwide-claude update

  # Check everything is working
  pacificwide-claude doctor

  # See available skills and stacks
  pacificwide-claude list

${BOLD}PROTECTED FILES${NC} (never overwritten)
  .mcp.json                      (project root — MCP server config)
  .claude/.env
  .claude/settings.local.json
  .claude/.pacificwide-meta.json

EOF
}

# ─── Main ─────────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    init)        cmd_init "$@" ;;
    update)      cmd_update "$@" ;;
    doctor)      cmd_doctor "$@" ;;
    list)        cmd_list "$@" ;;
    mcp)         cmd_mcp "$@" ;;
    reset)       cmd_reset "$@" ;;
    self-update) cmd_self_update "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help)       cmd_help ;;
    *)
      error "Unknown command: ${cmd}"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
