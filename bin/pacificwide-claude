#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# pacificwide-claude — Distribute team .claude/ config to any repo
# ─────────────────────────────────────────────────────────────────────────────

VERSION="1.0.0"
CLI_DIR="${HOME}/.pacificwide-claude"
CONFIG_SRC="${CLI_DIR}/config"
CLAUDE_DIR=".claude"
META_FILE="${CLAUDE_DIR}/.pacificwide-meta.json"

# Protected files — never overwritten by update/init
PROTECTED_FILES=(".env" "settings.local.json" ".mcp.json" ".pacificwide-meta.json")

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ─── Helpers ──────────────────────────────────────────────────────────────────

info()    { echo -e "${BLUE}ℹ${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}⚠${NC} $*"; }
error()   { echo -e "${RED}✗${NC} $*" >&2; }

is_protected() {
  local file="$1"
  for p in "${PROTECTED_FILES[@]}"; do
    if [[ "$file" == "$p" || "$file" == *"/$p" ]]; then
      return 0
    fi
  done
  return 1
}

write_meta() {
  local dir="$1"
  cat > "${dir}/${META_FILE}" <<EOF
{
  "version": "${VERSION}",
  "lastSync": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "source": "pacificwide-claude"
}
EOF
}

check_cli_installed() {
  if [[ ! -d "$CLI_DIR" ]]; then
    error "pacificwide-claude not installed at ${CLI_DIR}"
    echo "  Run: curl -fsSL https://raw.githubusercontent.com/Pacificwide-Real-Estate-Mortgage-CRM/pacificwide-claude/main/install.sh | bash"
    exit 1
  fi
}

sync_config() {
  local target_dir="$1"
  local count=0
  local skipped=0

  # Walk config/ and copy to target, preserving directory structure
  while IFS= read -r -d '' src_file; do
    # Get relative path from config/
    local rel_path="${src_file#${CONFIG_SRC}/}"
    local dest_file="${target_dir}/${CLAUDE_DIR}/${rel_path}"
    local dest_dir
    dest_dir="$(dirname "$dest_file")"

    # Skip protected files
    if is_protected "$rel_path"; then
      skipped=$((skipped + 1))
      continue
    fi

    # Check if destination exists and is protected
    local basename
    basename="$(basename "$rel_path")"
    if is_protected "$basename" && [[ -f "$dest_file" ]]; then
      skipped=$((skipped + 1))
      continue
    fi

    mkdir -p "$dest_dir"
    cp "$src_file" "$dest_file"
    count=$((count + 1))
  done < <(find "$CONFIG_SRC" -type f -print0)

  echo "${count}:${skipped}"
}

# ─── Commands ─────────────────────────────────────────────────────────────────

cmd_init() {
  check_cli_installed

  if [[ -d "$CLAUDE_DIR" ]]; then
    warn ".claude/ already exists in this directory."
    read -r -p "  Overwrite team config files? (protected files preserved) [y/N] " answer
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
      info "Aborted."
      exit 0
    fi
  fi

  info "Initializing .claude/ with team config..."
  mkdir -p "$CLAUDE_DIR"

  # Sync config files
  local result
  result="$(sync_config ".")"
  local count="${result%%:*}"
  local skipped="${result##*:}"

  # Copy .env.example if exists and .env doesn't
  if [[ -f "${CLI_DIR}/.env.example" && ! -f "${CLAUDE_DIR}/.env" ]]; then
    cp "${CLI_DIR}/.env.example" "${CLAUDE_DIR}/.env"
    success "Created .claude/.env from template"
  fi

  # Copy .mcp.json.example if exists and .mcp.json doesn't
  if [[ -f "${CLI_DIR}/.mcp.json.example" && ! -f "${CLAUDE_DIR}/.mcp.json" ]]; then
    cp "${CLI_DIR}/.mcp.json.example" "${CLAUDE_DIR}/.mcp.json"
    success "Created .claude/.mcp.json from template"
  fi

  # Write meta
  write_meta "."

  echo ""
  success "Initialized .claude/ with team config"
  echo -e "  ${CYAN}${count}${NC} files synced, ${CYAN}${skipped}${NC} protected files skipped"
  echo ""
  echo -e "  ${BOLD}Structure:${NC}"
  find "$CLAUDE_DIR" -type f | sort | sed 's/^/    /'
  echo ""
  info "Run ${BOLD}pacificwide-claude doctor${NC} to verify setup."
}

cmd_update() {
  check_cli_installed

  if [[ ! -f "$META_FILE" ]]; then
    error "Not a pacificwide-claude project. Run ${BOLD}pacificwide-claude init${NC} first."
    exit 1
  fi

  info "Pulling latest config..."
  if git -C "$CLI_DIR" pull --ff-only 2>/dev/null; then
    success "Config repo updated"
  else
    warn "Could not pull (offline or no changes). Using local config."
  fi

  info "Syncing config/ → .claude/ ..."
  local result
  result="$(sync_config ".")"
  local count="${result%%:*}"
  local skipped="${result##*:}"

  # Update meta
  write_meta "."

  echo ""
  success "Update complete"
  echo -e "  ${CYAN}${count}${NC} files synced, ${CYAN}${skipped}${NC} protected files preserved"
}

cmd_doctor() {
  check_cli_installed

  local pass=0
  local fail=0

  echo -e "${BOLD}pacificwide-claude doctor${NC}"
  echo ""

  # 1. CLI version vs remote
  echo -n "  CLI installed at ${CLI_DIR}... "
  if [[ -d "$CLI_DIR" ]]; then
    echo -e "${GREEN}PASS${NC} (v${VERSION})"
    pass=$((pass + 1))
  else
    echo -e "${RED}FAIL${NC}"
    fail=$((fail + 1))
  fi

  # 2. .claude/ exists + has meta.json
  echo -n "  .claude/ exists with meta... "
  if [[ -f "$META_FILE" ]]; then
    local last_sync
    last_sync="$(grep '"lastSync"' "$META_FILE" 2>/dev/null | sed 's/.*: *"\(.*\)".*/\1/' || echo "unknown")"
    echo -e "${GREEN}PASS${NC} (last sync: ${last_sync})"
    pass=$((pass + 1))
  elif [[ -d "$CLAUDE_DIR" ]]; then
    echo -e "${YELLOW}WARN${NC} (.claude/ exists but no meta — run ${BOLD}pacificwide-claude init${NC})"
    fail=$((fail + 1))
  else
    echo -e "${RED}FAIL${NC} (no .claude/ found — run ${BOLD}pacificwide-claude init${NC})"
    fail=$((fail + 1))
  fi

  # 3. Validate structure
  local dirs=("agents" "rules" "skills")
  for dir in "${dirs[@]}"; do
    echo -n "  .claude/${dir}/ exists... "
    if [[ -d "${CLAUDE_DIR}/${dir}" ]]; then
      local file_count
      file_count="$(find "${CLAUDE_DIR}/${dir}" -type f | wc -l | tr -d ' ')"
      echo -e "${GREEN}PASS${NC} (${file_count} files)"
      pass=$((pass + 1))
    else
      echo -e "${RED}FAIL${NC}"
      fail=$((fail + 1))
    fi
  done

  # 4. Check Node.js >= 18
  echo -n "  Node.js >= 18... "
  if command -v node &>/dev/null; then
    local node_ver
    node_ver="$(node -v | sed 's/v//' | cut -d. -f1)"
    if [[ "$node_ver" -ge 18 ]]; then
      echo -e "${GREEN}PASS${NC} ($(node -v))"
      pass=$((pass + 1))
    else
      echo -e "${RED}FAIL${NC} ($(node -v) — need >= 18)"
      fail=$((fail + 1))
    fi
  else
    echo -e "${RED}FAIL${NC} (not installed)"
    fail=$((fail + 1))
  fi

  # 5. Check git
  echo -n "  git installed... "
  if command -v git &>/dev/null; then
    echo -e "${GREEN}PASS${NC} ($(git --version | head -1))"
    pass=$((pass + 1))
  else
    echo -e "${RED}FAIL${NC}"
    fail=$((fail + 1))
  fi

  # 6. Check Claude Code CLI
  echo -n "  Claude Code CLI... "
  if command -v claude &>/dev/null; then
    echo -e "${GREEN}PASS${NC}"
    pass=$((pass + 1))
  else
    echo -e "${YELLOW}WARN${NC} (not found — install from https://claude.ai/code)"
    fail=$((fail + 1))
  fi

  echo ""
  if [[ $fail -eq 0 ]]; then
    success "All checks passed (${pass}/${pass})"
  else
    warn "${pass} passed, ${fail} failed"
  fi
}

cmd_list() {
  check_cli_installed

  local category="${1:-all}"

  echo -e "${BOLD}pacificwide-claude config${NC}"
  echo ""

  list_category() {
    local name="$1"
    local config_dir="$2"
    local claude_dir="$3"

    echo -e "  ${BOLD}${name}:${NC}"
    if [[ ! -d "$config_dir" ]]; then
      echo "    (none)"
      return
    fi

    while IFS= read -r file; do
      local rel="${file#${config_dir}/}"
      local basename
      basename="$(basename "$rel" .md)"
      basename="$(basename "$basename" .MD)"
      # Check if it's a SKILL.md (skill dir structure)
      if [[ "$basename" == "SKILL" ]]; then
        basename="$(basename "$(dirname "$rel")")"
      fi

      local status=""
      local dest="${claude_dir}/${rel}"
      if [[ -f "$dest" ]]; then
        status="${GREEN}active${NC}"
      else
        status="${YELLOW}available${NC}"
      fi

      echo -e "    ${basename}  [${status}]"
    done < <(find "$config_dir" -type f \( -name "*.md" -o -name "*.MD" \) | sort)
    echo ""
  }

  if [[ "$category" == "all" || "$category" == "agents" ]]; then
    list_category "Agents" "${CONFIG_SRC}/agents" "${CLAUDE_DIR}/agents"
  fi
  if [[ "$category" == "all" || "$category" == "rules" ]]; then
    list_category "Rules" "${CONFIG_SRC}/rules" "${CLAUDE_DIR}/rules"
  fi
  if [[ "$category" == "all" || "$category" == "skills" ]]; then
    list_category "Skills" "${CONFIG_SRC}/skills" "${CLAUDE_DIR}/skills"
  fi
}

cmd_reset() {
  check_cli_installed

  warn "This will remove .claude/ and re-initialize from team config."
  read -r -p "  Continue? [y/N] " answer
  if [[ ! "$answer" =~ ^[Yy]$ ]]; then
    info "Aborted."
    exit 0
  fi

  # Backup protected files
  local backup_dir
  backup_dir="$(mktemp -d)"
  local backed_up=()

  for file in "${PROTECTED_FILES[@]}"; do
    if [[ -f "${CLAUDE_DIR}/${file}" ]]; then
      mkdir -p "${backup_dir}/$(dirname "$file")"
      cp "${CLAUDE_DIR}/${file}" "${backup_dir}/${file}"
      backed_up+=("$file")
    fi
  done

  if [[ ${#backed_up[@]} -gt 0 ]]; then
    info "Backed up protected files: ${backed_up[*]}"
  fi

  # Remove .claude/
  rm -rf "$CLAUDE_DIR"
  success "Removed .claude/"

  # Re-init
  cmd_init

  # Restore backups
  for file in "${backed_up[@]}"; do
    cp "${backup_dir}/${file}" "${CLAUDE_DIR}/${file}"
    success "Restored ${file}"
  done

  rm -rf "$backup_dir"
  echo ""
  success "Reset complete. Protected files preserved."
}

cmd_self_update() {
  check_cli_installed

  info "Updating pacificwide-claude..."
  if git -C "$CLI_DIR" pull --ff-only; then
    local new_version
    new_version="$(grep '^VERSION=' "${CLI_DIR}/bin/pacificwide-claude" | head -1 | cut -d'"' -f2)"
    echo ""
    success "Updated to v${new_version:-${VERSION}}"
  else
    error "Failed to update. Check your network or git config."
    exit 1
  fi
}

cmd_version() {
  echo "pacificwide-claude v${VERSION}"
}

cmd_help() {
  cat <<EOF
${BOLD}pacificwide-claude${NC} v${VERSION} — Team .claude/ config manager

${BOLD}USAGE${NC}
  pacificwide-claude <command> [options]

${BOLD}COMMANDS${NC}
  init              Initialize .claude/ in current project with team config
  update            Pull latest config and sync to .claude/
  doctor            Check setup and environment
  list [category]   List available config (agents|rules|skills|all)
  reset             Remove .claude/ and re-initialize (preserves .env)
  self-update       Update the CLI itself
  version           Show version
  help              Show this help

${BOLD}EXAMPLES${NC}
  # First time setup in a new project
  cd my-project
  pacificwide-claude init

  # Get latest team config
  pacificwide-claude update

  # Check everything is working
  pacificwide-claude doctor

  # See available skills
  pacificwide-claude list skills

${BOLD}PROTECTED FILES${NC} (never overwritten)
  .claude/.env
  .claude/settings.local.json
  .claude/.mcp.json
  .claude/.pacificwide-meta.json

EOF
}

# ─── Main ─────────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    init)        cmd_init "$@" ;;
    update)      cmd_update "$@" ;;
    doctor)      cmd_doctor "$@" ;;
    list)        cmd_list "$@" ;;
    reset)       cmd_reset "$@" ;;
    self-update) cmd_self_update "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help)       cmd_help ;;
    *)
      error "Unknown command: ${cmd}"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
